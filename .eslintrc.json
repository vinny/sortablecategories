{
  "env": {
    "browser": true,
    "jquery": true,
    "es6": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": 2015
  },
  "rules": {
    "no-unused-vars": ["error", { "argsIgnorePattern": "^_" }],
    "indent": ["error", "tab", { "SwitchCase": 1 }],
    "quotes": ["error", "single"],
    "semi": ["error", "always"]
  },
  "globals": {
    "SORTABLE_CATEGORIES_URL": "readonly",
    "Sortable": "readonly"
  },
  "ignorePatterns": [
    "**/sortable.min.js"
  ]
}
