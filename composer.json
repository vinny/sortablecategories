{
    "name": "vinny/sortablecategories",
    "type": "phpbb-extension",
    "description": "Allows users to reorganize forum categories using drag and drop on the index page",
    "homepage": "https://github.com/vinny/sortablecategories",
    "version": "1.0.0",
    "license": "GPL-2.0-only",
    "authors": [
        {
            "name": "Vinny",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=7.2.0",
        "composer/installers": "~1.0.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.10",
        "friendsoftwig/twigcs": "^5.0",
        "squizlabs/php_codesniffer": "^3.8"
    },
    "scripts": {
        "phpstan": "phpstan analyse",
        "phpcs": "phpcs",
        "twigcs": "twigcs styles --twig-version 2"
    },
    "extra": {
        "display-name": "Sortable Categories",
        "soft-require": {
            "phpbb/phpbb": ">=3.3.0,<4.0.0@dev"
        },
        "version-check": {
            "host": "www.phpbb.com",
            "directory": "/customise/db/extension/sortablecategories",
            "filename": "version_check",
            "ssl": true
        }
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true
        }
    }
}
